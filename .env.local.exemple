# ============================================================
# Configuração para execução LOCAL do SlkImportContratosLambda
# ============================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# O arquivo .env.local NUNCA deve ser commitado no git.

# ---------------------------------------------------------------
# Banco de dados local (MySQL)
# ---------------------------------------------------------------
DB_HOST=localhost
DB_NAME=nome_do_seu_banco
DB_USER=root
DB_PASSWORD=sua_senha_aqui

# ---------------------------------------------------------------
# Google Credentials (service account JSON)
# ---------------------------------------------------------------
# Caminho para o arquivo JSON de credenciais da service account do Google.
# Baixe em: Google Cloud Console → IAM → Service Accounts → chave JSON
LOCAL_GOOGLE_CREDENTIALS_PATH=./google_credentials.json

# ---------------------------------------------------------------
# Variável exigida pelo main.py (não usada localmente, mas precisa existir)
# ---------------------------------------------------------------
GOOGLE_SECRET_ARN=local-not-used
